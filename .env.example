DATABASE_URL=file:./data/crustopher.db
SESSION_SECRET=change-me-to-32-bytes-of-random-hex
PUBLIC_BASE_URL=http://localhost:3000

# Telegram (optional — set after creating bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-random-string

# Optional — if set, the first-run setup page is bypassed and this admin is seeded.
# Generate with: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'your-password'
ADMIN_PASSWORD_HASH=
ADMIN_DISPLAY_NAME=Baker
