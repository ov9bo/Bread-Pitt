DATABASE_URL=file:./data/bread-pitt.db
SESSION_SECRET=change-me-to-32-bytes-of-random-hex
PUBLIC_BASE_URL=http://localhost:3000

# Telegram (optional — set after creating bot via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-random-string

# Optional — if set, the first-run setup page is bypassed and this admin is seeded.
# Generate with: node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'your-password'
ADMIN_PASSWORD_HASH=
ADMIN_DISPLAY_NAME=Baker

# Google Calendar OAuth (optional — set to enable per-user calendar sync).
# Create OAuth credentials in https://console.cloud.google.com/, enable the
# Calendar API, and add the redirect URL to the Authorized redirect URIs.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/api/google/oauth/callback
